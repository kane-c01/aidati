.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.DS_Store
Thumbs.db
*.swp
*.swo

# === 测试 / 覆盖率 ===
coverage/
.nyc_output/
*.lcov

# === Docker 数据卷 ===
deploy/data/
deploy/.minio-data/
deploy/.mysql-data/

# === 微信开发者工具临时产物 ===
