*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.python-version
.mypy_cache/
.ruff_cache/
.pytest_cache/

# === 构建产物 ===
dist/
build/
*.tsbuildinfo
.next/
out/
miniprogram/miniprogram_npm/

# === 环境变量与密钥(按 §5.1 强制隔离) ===
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
!*.example
!.env.example
!.env.development
miniprogram/wxconfig.local.json

# === IDE / 编辑器 ===
