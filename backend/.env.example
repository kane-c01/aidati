# ========================================
# AI 智能出题学习小程序 - 业务后端环境变量
# 文档:开发文档/05-部署运维与安全.md §2.3
# ⚠️ 本文件仅样例;真实 .env 严禁提交 git
# ========================================

NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_VERSION=0.1.0

# === 数据库 ===
# 本地 docker compose 起 MySQL 后默认连接串(宿主机端口 3307)
DATABASE_URL=mysql://app:dev_app@localhost:3307/ai_quiz

# === Redis ===
# 宿主机端口 6380(避免与其它本地 Redis 冲突)
REDIS_URL=redis://localhost:6380
REDIS_PREFIX=ai-quiz:dev:

# === JWT(生产请用 openssl rand -hex 32 生成)===
JWT_SECRET=__change_me_to_openssl_rand_hex_32__
JWT_REFRESH_SECRET=__change_me_to_openssl_rand_hex_32_different__
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# === 微信小程序 ===
WECHAT_APPID=__from_wechat_console__
WECHAT_SECRET=__from_wechat_console__

# === 对象存储(本地用 MinIO 模拟,生产用腾讯云 COS / 阿里云 OSS)===
OSS_PROVIDER=minio
OSS_ENDPOINT=http://localhost:9000
OSS_REGION=us-east-1
OSS_BUCKET=ai-quiz-dev
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_PUBLIC_BASE=http://localhost:9000/ai-quiz-dev

# === 大模型 ===
LLM_PRIMARY_PROVIDER=deepseek
DEEPSEEK_API_KEY=__from_provider__
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=__optional__
GLM_API_KEY=__optional__

# === OCR(微信原生 + 腾讯云备援)===
OCR_PRIMARY=wechat
TENCENT_CLOUD_SECRET_ID=__optional__
TENCENT_CLOUD_SECRET_KEY=__optional__
TENCENT_CLOUD_REGION=ap-guangzhou

# === AI 编排服务地址(后端 → ai-service)===
AI_SERVICE_BASE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_TOKEN=__shared_with_ai_service__

# === 监控 / 日志 ===
SENTRY_DSN=
LOG_LEVEL=debug
