# ========================================
# AI 智能出题学习小程序 - AI 编排服务环境变量
# 文档:开发文档/05-部署运维与安全.md §2.3
# ⚠️ 本文件仅样例;真实 .env 严禁提交 git
# ========================================

ENV=development
PORT=8000
LOG_LEVEL=INFO
VERSION=0.1.0

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM(已备案的国内大模型,见 PRD §7.5.3)===
LLM_PRIMARY_PROVIDER=deepseek
DEEPSEEK_API_KEY=__from_provider__
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=__optional__
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GLM_API_KEY=__optional__
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# === 微信(用于内容安全 API access_token)===
WECHAT_APPID=__from_wechat_console__
WECHAT_SECRET=__from_wechat_console__

# === 后端回调 ===
BACKEND_CALLBACK_URL=http://localhost:3000/v1
INTERNAL_TOKEN=__shared_with_backend__
