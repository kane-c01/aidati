/**
 * 全局样式 + 设计 Token
 *
 * 来源: 开发文档/06-UI设计规范.md §2
 * 风格: Quietly Smart(安静而智能)
 *
 * 注:小程序 WXSS 不支持 :root, 用 page 选择器声明 CSS 变量。
 */

page {
  /* ===== 品牌色 ===== */
  --color-primary: #5b5bd6;
  --color-primary-hover: #4949c4;
  --color-primary-disabled: #c8c8f0;
  --color-primary-bg: #eeeefc;
  --color-secondary: #4a6fa5;

  /* ===== 功能色 ===== */
  --color-success: #1dbf73;
  --color-success-bg: #e5f8ee;
  --color-warning: #f5a623;
  --color-warning-bg: #fef3dd;
  --color-danger: #e14c4c;
  --color-danger-bg: #fce8e8;
  --color-info: #4a6fa5;

  /* ===== 中性色 ===== */
  --color-text-primary: #1a1a1a;
  --color-text-secondary: #4a4a4a;
  --color-text-tertiary: #8c8c8c;
  --color-text-disabled: #bfbfbf;
  --color-text-inverse: #ffffff;
  --color-border: #e8e6e1;
  --color-border-light: #f0eeea;
  --color-bg-page: #fafaf7;
  --color-bg-card: #ffffff;
  --color-bg-elevated: #ffffff;
  --color-bg-overlay: rgba(20, 20, 20, 0.5);

  /* ===== 圆角 ===== */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 999rpx;

  /* ===== 阴影 ===== */
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  --shadow-card-hover: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  --shadow-popover: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  --shadow-fab: 0 6rpx 16rpx rgba(91, 91, 214, 0.3);

  /* ===== 间距 ===== */
  --space-xxs: 4rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-xxl: 64rpx;

  /* ===== 字号 ===== */
  --font-display: 60rpx;
  --font-h1: 44rpx;
  --font-h2: 36rpx;
  --font-h3: 32rpx;
  --font-body: 28rpx;
  --font-caption: 24rpx;
  --font-tiny: 22rpx;

  /* ===== 动效 ===== */
  --ease-quick: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --ease-base: 250ms cubic-bezier(0.4, 0, 0.2, 1);
  --ease-slow: 400ms cubic-bezier(0.2, 0.8, 0.2, 1);

  /* ===== 页面基线 ===== */
  background-color: var(--color-bg-page);
  font-family:
    -apple-system, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei',
    'Source Han Sans CN', sans-serif;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ===== 通用 utility ===== */

.container {
  padding: var(--space-lg);
  box-sizing: border-box;
}

.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  border: none;
  transition: transform var(--ease-quick);
}

.btn-primary:active {
  transform: scale(0.97);
  background-color: var(--color-primary-hover);
}

.btn-primary[disabled],
.btn-primary.disabled {
  background-color: var(--color-primary-disabled);
  color: var(--color-text-inverse);
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-primary);
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: transparent;
  color: var(--color-primary);
  font-size: 32rpx;
  border: none;
}

.btn-danger {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: 32rpx;
  border-radius: var(--radius-md);
  border: none;
}

/* ===== 文字色阶 ===== */
.text-primary {
  color: var(--color-text-primary);
}
.text-secondary {
  color: var(--color-text-secondary);
}
.text-tertiary {
  color: var(--color-text-tertiary);
}
.text-disabled {
  color: var(--color-text-disabled);
}

.font-display {
  font-size: var(--font-display);
  font-weight: 700;
  line-height: 1.3;
}
.font-h1 {
  font-size: var(--font-h1);
  font-weight: 700;
  line-height: 1.4;
}
.font-h2 {
  font-size: var(--font-h2);
  font-weight: 500;
  line-height: 1.4;
}
.font-h3 {
  font-size: var(--font-h3);
  font-weight: 500;
  line-height: 1.5;
}
.font-body {
  font-size: var(--font-body);
}
.font-caption {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
  line-height: 1.5;
}
.font-tiny {
  font-size: var(--font-tiny);
}

/* ===== 安全区适配 ===== */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 列表分割线 ===== */
.divider {
  height: 1rpx;
  background-color: var(--color-border-light);
  margin: var(--space-sm) 0;
}

/* ===== 隐藏 scrollbar ===== */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ===== 通用 flex ===== */
.row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.row-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.column {
  display: flex;
  flex-direction: column;
}
.gap-xs {
  gap: var(--space-xs);
}
.gap-sm {
  gap: var(--space-sm);
}
.gap-md {
  gap: var(--space-md);
}
.gap-lg {
  gap: var(--space-lg);
}

/* ===== ellipsis ===== */
.ellipsis-1 {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}
.ellipsis-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}
