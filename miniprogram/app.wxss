/**
 * 全局样式 + 设计 Token
 *
 * 来源:开发文档/06-UI 设计规范.md §2  风格:Quietly Smart
 *
 * 调色思路(Q3 微调):
 *  - 把页面底色从偏黄的 #fafaf7 换成偏冷的 #f6f6fb, 与品牌紫更和谐
 *  - 品牌渐变去掉旧版的灰蓝中段(原 4a6fa5), 改紫到深紫递进
 *  - 功能色略降饱和度, 让整体更稳更"哑光"
 *  - 边框冷调化, 阴影轻染品牌色
 *
 * 注:小程序 WXSS 不支持 :root, 用 page 选择器声明 CSS 变量
 */

page {
  /* ===== 品牌色 ===== */
  --color-primary: #5b5bd6;
  --color-primary-hover: #4747c2;
  --color-primary-active: #3935a8;
  --color-primary-disabled: #c5c4f1;
  --color-primary-bg: #eeedfd;
  --color-primary-bg-soft: #f5f4fe;
  --color-secondary: #6b7da8;
  --gradient-brand: linear-gradient(135deg, #7a77e5 0%, #5b5bd6 52%, #443dbe 100%);
  --gradient-brand-soft: linear-gradient(135deg, #f5f4fe 0%, #eceafc 100%);
  --gradient-warm: linear-gradient(135deg, #fff3d9 0%, #ffdfa6 100%);

  /* ===== 功能色(略降饱和) ===== */
  --color-success: #16a773;
  --color-success-bg: #e2f5eb;
  --color-warning: #e2941d;
  --color-warning-bg: #fcf1dc;
  --color-danger: #dc4848;
  --color-danger-bg: #fbe7e7;
  --color-info: #4a6fa5;
  --color-info-bg: #ebf1f9;

  /* ===== 中性色(冷化) ===== */
  --color-text-primary: #16161d;
  --color-text-secondary: #44444b;
  --color-text-tertiary: #8a8a95;
  --color-text-disabled: #b5b5c0;
  --color-text-inverse: #ffffff;
  --color-border: #e4e3ec;
  --color-border-light: #f0eff5;
  --color-bg-page: #f6f6fb;
  --color-bg-card: #ffffff;
  --color-bg-elevated: #ffffff;
  --color-bg-soft: #f1f1f7;
  --color-bg-overlay: rgba(20, 20, 30, 0.5);

  /* ===== 圆角 ===== */
  --radius-xs: 6rpx;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-pill: 999rpx;

  /* ===== 阴影 ===== */
  --shadow-card: 0 2rpx 14rpx rgba(20, 20, 30, 0.04);
  --shadow-card-hover: 0 4rpx 22rpx rgba(20, 20, 30, 0.08);
  --shadow-popover: 0 8rpx 36rpx rgba(20, 20, 30, 0.1);
  --shadow-fab: 0 6rpx 22rpx rgba(91, 91, 214, 0.32);
  --shadow-hero: 0 12rpx 44rpx rgba(91, 91, 214, 0.2);

  /* ===== 间距 ===== */
  --space-xxs: 4rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-xxl: 64rpx;

  /* ===== 字号 ===== */
  --font-display: 64rpx;
  --font-h1: 44rpx;
  --font-h2: 36rpx;
  --font-h3: 32rpx;
  --font-body: 28rpx;
  --font-caption: 24rpx;
  --font-tiny: 22rpx;

  /* ===== 动效 ===== */
  --ease-quick: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --ease-base: 250ms cubic-bezier(0.4, 0, 0.2, 1);
  --ease-slow: 400ms cubic-bezier(0.2, 0.8, 0.2, 1);

  /* ===== 页面基线 ===== */
  background-color: var(--color-bg-page);
  font-family:
    -apple-system, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei',
    'Source Han Sans CN', sans-serif;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ======================================================================
 * 通用容器
 * ====================================================================== */

.page-pad {
  padding: 0 var(--space-lg);
  box-sizing: border-box;
}

.container {
  padding: var(--space-lg);
  box-sizing: border-box;
}

.section {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  font-size: var(--font-h3);
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.section-title__more {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
  font-weight: 400;
}

/* ======================================================================
 * 卡片
 * ====================================================================== */

.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
  transition: transform var(--ease-quick), box-shadow var(--ease-quick);
}

.card--lg {
  border-radius: var(--radius-lg);
  padding: var(--space-xl) var(--space-lg);
}

.card--soft {
  background-color: var(--color-primary-bg-soft);
  box-shadow: none;
  border: 1rpx solid var(--color-border-light);
}

.card--elevated {
  box-shadow: var(--shadow-card-hover);
}

.card:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-card);
}

.tappable:active {
  transform: scale(0.98);
  opacity: 0.9;
  transition: all var(--ease-quick);
}

/* ======================================================================
 * 按钮
 * ====================================================================== */

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  border: none;
  transition: transform var(--ease-quick), opacity var(--ease-quick);
  letter-spacing: 1rpx;
  line-height: 1;
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.92;
}

.btn--primary {
  background-color: var(--color-primary);
  background-image: var(--gradient-brand);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-fab);
}

.btn--secondary {
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  box-shadow: none;
}

.btn--ghost {
  background-color: transparent;
  color: var(--color-primary);
  box-shadow: none;
}

.btn--danger {
  background-color: var(--color-danger);
  color: var(--color-text-inverse);
}

.btn--lg {
  height: 96rpx;
  font-size: 32rpx;
  border-radius: var(--radius-lg);
}

.btn--sm {
  height: 64rpx;
  font-size: 26rpx;
  padding: 0 var(--space-md);
}

.btn--pill {
  border-radius: var(--radius-pill);
}

.btn--block {
  width: 100%;
}

.btn[disabled],
.btn.disabled {
  background-color: var(--color-primary-disabled);
  background-image: none;
  color: var(--color-text-inverse);
  box-shadow: none;
  pointer-events: none;
}

/* 旧命名兼容 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: var(--color-primary);
  background-image: var(--gradient-brand);
  color: var(--color-text-inverse);
  font-size: 30rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  border: none;
  transition: transform var(--ease-quick);
  box-shadow: var(--shadow-fab);
  letter-spacing: 1rpx;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.92;
}

.btn-primary[disabled],
.btn-primary.disabled {
  background-image: none;
  background-color: var(--color-primary-disabled);
  color: var(--color-text-inverse);
  box-shadow: none;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-primary);
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: transparent;
  color: var(--color-primary);
  font-size: 30rpx;
  border: none;
}

.btn-danger {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: 30rpx;
  border-radius: var(--radius-md);
  border: none;
}

/* ======================================================================
 * 文字色阶
 * ====================================================================== */

.text-primary {
  color: var(--color-text-primary);
}
.text-secondary {
  color: var(--color-text-secondary);
}
.text-tertiary {
  color: var(--color-text-tertiary);
}
.text-disabled {
  color: var(--color-text-disabled);
}
.text-success {
  color: var(--color-success);
}
.text-warning {
  color: var(--color-warning);
}
.text-danger {
  color: var(--color-danger);
}
.text-brand {
  color: var(--color-primary);
}

.font-display {
  font-size: var(--font-display);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.5rpx;
}
.font-h1 {
  font-size: var(--font-h1);
  font-weight: 700;
  line-height: 1.4;
}
.font-h2 {
  font-size: var(--font-h2);
  font-weight: 600;
  line-height: 1.4;
}
.font-h3 {
  font-size: var(--font-h3);
  font-weight: 500;
  line-height: 1.5;
}
.font-body {
  font-size: var(--font-body);
}
.font-body-strong {
  font-size: var(--font-body);
  font-weight: 500;
}
.font-caption {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
  line-height: 1.5;
}
.font-tiny {
  font-size: var(--font-tiny);
}

/* ======================================================================
 * 标签 / Tag / Pill
 * ====================================================================== */

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: var(--radius-pill);
  font-size: var(--font-tiny);
  line-height: 1.2;
  white-space: nowrap;
}

.tag--success {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}
.tag--warning {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}
.tag--danger {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}
.tag--info {
  background-color: var(--color-info-bg);
  color: var(--color-info);
}
.tag--ghost {
  background-color: transparent;
  color: var(--color-text-tertiary);
  border: 1rpx solid var(--color-border-light);
}

/* ======================================================================
 * 书名封面 (Title-as-Cover)
 *
 * 不依赖图片, 用排版 + 上下细线 + 调子色块, 让书名本身成为封面视觉
 * 4 个尺寸:--sm / --md / --lg / --xl
 * 6 个调子:--tone-0 ~ --tone-5, 由 cover.ts 的 hash 决定, 让列表不至于一片同色
 * ====================================================================== */

.book-title-cover {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 22rpx 16rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid rgba(20, 20, 30, 0.05);
}

.book-title-cover::before,
.book-title-cover::after {
  content: '';
  position: absolute;
  left: 16%;
  right: 16%;
  height: 1rpx;
  background-color: currentColor;
  opacity: 0.22;
}
.book-title-cover::before { top: 16%; }
.book-title-cover::after { bottom: 16%; }

.book-title-cover__title {
  font-weight: 700;
  letter-spacing: 2rpx;
  line-height: 1.25;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-title-cover__author {
  margin-top: 12rpx;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  opacity: 0.55;
  max-width: 80%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-title-cover--sm {
  padding: 12rpx 8rpx;
}
.book-title-cover--sm::before { top: 14%; }
.book-title-cover--sm::after { bottom: 14%; }
.book-title-cover--sm .book-title-cover__title {
  font-size: 30rpx;
  letter-spacing: 1rpx;
  -webkit-line-clamp: 3;
}
.book-title-cover--sm .book-title-cover__author { display: none; }

.book-title-cover--md .book-title-cover__title { font-size: 38rpx; }

.book-title-cover--lg .book-title-cover__title {
  font-size: 56rpx;
  letter-spacing: 4rpx;
  -webkit-line-clamp: 3;
}

.book-title-cover--xl .book-title-cover__title {
  font-size: 84rpx;
  letter-spacing: 6rpx;
  -webkit-line-clamp: 3;
}
.book-title-cover--xl .book-title-cover__author {
  font-size: 24rpx;
  margin-top: 18rpx;
}

/* tone palettes — 取自 6 种"书脊"调子 */
.book-title-cover--tone-0 {
  background-image: linear-gradient(160deg, #f3f0e6 0%, #ebe6d6 100%);
  color: #2a2620;
}
.book-title-cover--tone-1 {
  background-image: linear-gradient(160deg, #ecf1ec 0%, #dbe5dc 100%);
  color: #1f2c25;
}
.book-title-cover--tone-2 {
  background-image: linear-gradient(160deg, #ebeff5 0%, #d9e0ec 100%);
  color: #1f2c3a;
}
.book-title-cover--tone-3 {
  background-image: linear-gradient(160deg, #f3e9e9 0%, #ead6d4 100%);
  color: #3a2424;
}
.book-title-cover--tone-4 {
  background-image: linear-gradient(160deg, #ede6f1 0%, #e0d4ec 100%);
  color: #2c1f3a;
}
.book-title-cover--tone-5 {
  background-image: linear-gradient(160deg, #f3ecda 0%, #ebdcb4 100%);
  color: #3a2e1f;
}

/* ======================================================================
 * 安全区
 * ====================================================================== */

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ======================================================================
 * 列表分割线
 * ====================================================================== */

.divider {
  height: 1rpx;
  background-color: var(--color-border-light);
  margin: var(--space-sm) 0;
}

/* ======================================================================
 * 隐藏 scrollbar
 * ====================================================================== */

::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ======================================================================
 * 通用 flex
 * ====================================================================== */

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.row-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.row-end {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
}
.column {
  display: flex;
  flex-direction: column;
}
.gap-xxs {
  gap: var(--space-xxs);
}
.gap-xs {
  gap: var(--space-xs);
}
.gap-sm {
  gap: var(--space-sm);
}
.gap-md {
  gap: var(--space-md);
}
.gap-lg {
  gap: var(--space-lg);
}

/* ======================================================================
 * 文本截断
 * ====================================================================== */

.ellipsis-1 {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}
.ellipsis-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

/* ======================================================================
 * Hero 卡片(首页 / 关键页用)
 * ====================================================================== */

.hero {
  position: relative;
  background-image: var(--gradient-brand);
  color: var(--color-text-inverse);
  border-radius: var(--radius-lg);
  padding: var(--space-xl) var(--space-lg);
  box-shadow: var(--shadow-hero);
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -180rpx;
  left: -80rpx;
  width: 380rpx;
  height: 380rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.hero__title {
  font-size: var(--font-h1);
  font-weight: 700;
  letter-spacing: 0.5rpx;
  position: relative;
  z-index: 1;
}

.hero__subtitle {
  margin-top: var(--space-xs);
  font-size: var(--font-caption);
  color: rgba(255, 255, 255, 0.85);
  position: relative;
  z-index: 1;
}

/* ======================================================================
 * 进度条
 * ====================================================================== */

.progress {
  position: relative;
  background-color: var(--color-border-light);
  border-radius: var(--radius-pill);
  overflow: hidden;
  height: 8rpx;
}

.progress__bar {
  position: absolute;
  inset: 0;
  background-image: var(--gradient-brand);
  border-radius: var(--radius-pill);
  transition: width var(--ease-base);
}

.progress--soft .progress__bar {
  background-image: linear-gradient(90deg, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0.95) 100%);
}

/* ======================================================================
 * 头像占位
 * ====================================================================== */

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-weight: 600;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ======================================================================
 * 自绘图标
 * ====================================================================== */

.icon-search,
.icon-arrow,
.icon-close,
.icon-check {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  position: relative;
  flex-shrink: 0;
}

.icon-search::before {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  top: 2rpx;
  left: 2rpx;
}
.icon-search::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 1rpx;
  bottom: 4rpx;
  right: 2rpx;
  transform: rotate(45deg);
  transform-origin: right;
}

.icon-arrow::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: translate(-65%, -50%) rotate(45deg);
}

.icon-close::before,
.icon-close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 18rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 1rpx;
}
.icon-close::before {
  transform: translate(-50%, -50%) rotate(45deg);
}
.icon-close::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.icon-check::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 12rpx;
  border-bottom: 3rpx solid currentColor;
  border-left: 3rpx solid currentColor;
  transform: translate(-50%, -65%) rotate(-45deg);
}
