<view class="tab-bar safe-area-bottom">
  <view
    class="tab-bar__item {{ active === 'home' ? 'tab-bar__item--active' : '' }}"
    data-key="home"
    bindtap="onTap"
  >
    <view class="tab-bar__icon-wrap">
      <view class="tab-icon tab-icon--book">
        <view class="tab-icon__book-spine"></view>
        <view class="tab-icon__book-line tab-icon__book-line--1"></view>
        <view class="tab-icon__book-line tab-icon__book-line--2"></view>
      </view>
    </view>
    <text class="tab-bar__text">书库</text>
  </view>
  <view
    class="tab-bar__item {{ active === 'photo' ? 'tab-bar__item--active' : '' }}"
    data-key="photo"
    bindtap="onTap"
  >
    <view class="tab-bar__icon-wrap">
      <view class="tab-icon tab-icon--camera">
        <view class="tab-icon__lens"></view>
        <view class="tab-icon__bump"></view>
      </view>
    </view>
    <text class="tab-bar__text">拍照</text>
  </view>
  <view
    class="tab-bar__item {{ active === 'profile' ? 'tab-bar__item--active' : '' }}"
    data-key="profile"
    bindtap="onTap"
  >
    <view class="tab-bar__icon-wrap">
      <view class="tab-icon tab-icon--person">
        <view class="tab-icon__head"></view>
        <view class="tab-icon__body"></view>
      </view>
    </view>
    <text class="tab-bar__text">我的</text>
  </view>
</view>
