.book-card {
  display: flex;
  align-items: stretch;
  gap: var(--space-md);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--ease-quick);
}

.book-card--hover {
  box-shadow: var(--shadow-card-hover);
}

.book-card__cover-wrap {
  position: relative;
  width: 120rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.book-card__fav {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(20, 20, 20, 0.18);
  transition: transform var(--ease-quick), background-color var(--ease-quick);
  color: var(--color-text-tertiary);
}
.book-card__fav--hover {
  transform: scale(0.92);
}
.book-card__fav--active {
  background-color: var(--color-warning-bg);
  border-color: rgba(245, 166, 35, 0.4);
  color: var(--color-warning);
}
.book-card__fav--busy {
  pointer-events: none;
  opacity: 0.7;
}

.book-card__fav-star {
  width: 26rpx;
  height: 26rpx;
  background-color: currentColor;
  clip-path: polygon(
    50% 0%,
    61% 35%,
    98% 35%,
    68% 57%,
    79% 91%,
    50% 70%,
    21% 91%,
    32% 57%,
    2% 35%,
    39% 35%
  );
}

.book-card__fav-spin {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border-light);
  border-top-color: var(--color-primary);
  animation: book-card-spin 0.8s linear infinite;
}

@keyframes book-card-spin {
  to {
    transform: rotate(360deg);
  }
}

.book-card__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  min-width: 0;
}

.book-card__title {
  font-size: var(--font-h3);
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.book-card__meta {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
}

.book-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-xs);
}

.book-card__tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-tiny);
  border-radius: var(--radius-sm);
}

.book-card__arrow {
  align-self: center;
  color: var(--color-text-tertiary);
  font-size: 36rpx;
}
