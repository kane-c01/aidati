<view class="book-card" hover-class="book-card--hover" hover-stay-time="80" bindtap="onTap">
  <image
    class="book-card__cover"
    src="{{book.cover_url || '/assets/cover-placeholder.png'}}"
    mode="aspectFill"
    lazy-load="{{true}}"
  />
  <view class="book-card__body">
    <text class="book-card__title ellipsis-2">{{book.title}}</text>
    <text class="book-card__meta">{{book.author}}{{book.category ? ' · ' + book.category : ''}}</text>
    <view class="book-card__tags" wx:if="{{tagList.length}}">
      <view wx:for="{{tagList}}" wx:key="*this" class="book-card__tag">
        {{item}}
      </view>
    </view>
  </view>
  <view class="book-card__arrow">›</view>
</view>
