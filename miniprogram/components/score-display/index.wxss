.score {
  display: flex;
  justify-content: center;
}

.score__ring {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--ease-slow);
}

.score__inner {
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  background-color: var(--color-bg-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card);
}

.score__num {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
}

.score__suffix {
  font-size: var(--font-body);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}
