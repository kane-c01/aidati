.hist {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx 24rpx 60rpx;
}

.hist__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 16rpx 8rpx 16rpx;
}

.hist__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.hist__sub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.hist__filter {
  padding: 0 4rpx 12rpx;
}

.hist__sub-filter {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  padding: 0 4rpx 16rpx;
}

.hist__sub-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 360rpx;
  padding: 10rpx 18rpx;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 999rpx;
  color: var(--color-text-secondary);
  transition: all var(--ease-quick);
}
.hist__sub-chip--hover {
  transform: scale(0.97);
}
.hist__sub-chip--active {
  background-color: var(--color-primary-bg);
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: 500;
}

.hist__sub-chip-label {
  font-size: 24rpx;
  letter-spacing: 0.4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hist__sub-chip-arrow {
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
  transform: rotate(45deg) translateY(-2rpx);
  flex-shrink: 0;
}

.hist__sub-clear {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  padding: 4rpx 8rpx;
  letter-spacing: 0.5rpx;
  text-decoration: underline;
}

.hist__loading {
  padding: 12rpx;
}

.hist__list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hist__row {
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: 20rpx;
  padding: 24rpx 26rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  transition: transform var(--ease-quick), background-color var(--ease-quick);
}
.hist__row--hover {
  transform: scale(0.99);
  background-color: var(--color-primary-bg-soft);
}

.hist__row-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.hist__row-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.hist__chip {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}
.hist__chip.tone-success {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}
.hist__chip.tone-warn {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}
.hist__chip.tone-info {
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
}
.hist__chip.tone-muted {
  background-color: var(--color-border-light);
  color: var(--color-text-tertiary);
}

.hist__src {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.4rpx;
}

.hist__time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.hist__row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 0.4rpx;
  line-height: 1.4;
}

.hist__row-sub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.4;
}

.hist__row-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 6rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.hist__stat {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.hist__stat-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.4rpx;
}

.hist__stat-value {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.hist__stat-num {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: -0.5rpx;
  line-height: 1;
  font-feature-settings: 'tnum' 1;
}

.hist__stat-unit {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

.hist__loadmore {
  text-align: center;
  padding: 32rpx 0 16rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.5rpx;
}

.hist__spacer {
  height: 80rpx;
}
