.up {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: var(--space-md) var(--space-lg) 200rpx;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.up__hero-title {
  font-size: var(--font-h1);
  font-weight: 600;
  color: var(--color-text-primary);
}
.up__hero-sub {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
  line-height: 1.6;
}

.up__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.up__field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.up__label {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.up__cover-area {
  position: relative;
  width: 200rpx;
  height: 280rpx;
}
.up__cover {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-border-light);
  border: 2rpx dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}
.up__cover-img {
  width: 100%;
  height: 100%;
}
.up__cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: var(--color-text-tertiary);
}
.up__cover-plus {
  font-size: 48rpx;
}
.up__cover-tip {
  font-size: var(--font-tiny);
}
.up__cover-clear {
  position: absolute;
  right: -16rpx;
  top: -16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.up__cover-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  border-radius: var(--radius-md);
  color: #fff;
  font-size: var(--font-caption);
  display: flex;
  align-items: center;
  justify-content: center;
}

.up__pdf {
  background: var(--color-bg-card);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
}
.up__pdf-pick {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  text-align: center;
}
.up__pdf-icon {
  font-size: 80rpx;
}
.up__pdf-tip {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  font-weight: 500;
}
.up__pdf-sub {
  font-size: var(--font-tiny);
  color: var(--color-text-tertiary);
}
.up__pdf-done {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}
.up__pdf-name {
  font-size: var(--font-caption);
  color: var(--color-text-primary);
  flex: 1;
  word-break: break-all;
}
.up__pdf-replace {
  font-size: var(--font-tiny);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
  flex-shrink: 0;
}

.up__input {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-body);
}

.up__textarea {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-body);
  width: 100%;
  box-sizing: border-box;
  min-height: 100rpx;
}

.up__action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--space-sm) var(--space-lg) var(--space-md);
  background: rgba(250, 250, 247, 0.96);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid var(--color-border-light);
}
.up__submit {
  width: 100%;
}
