.page {
  padding: 32rpx 32rpx 80rpx;
  background: #fafaf7;
  min-height: 100vh;
}

.hero {
  padding: 24rpx 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  color: #141414;
}

.meta {
  font-size: 24rpx;
  color: #8c8c8c;
}

.section {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.h {
  font-size: 30rpx;
  font-weight: 600;
  color: #141414;
}

.p {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

.li {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

.footer {
  margin-top: 48rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.6;
}
