.bd {
  padding: var(--space-lg) var(--space-lg) 240rpx;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.bd__loading {
  padding: var(--space-lg);
}

.bd__hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-lg);
}

.bd__cover {
  width: 280rpx;
  height: 380rpx;
  margin-bottom: var(--space-md);
  box-shadow: 0 8rpx 24rpx rgba(20, 20, 30, 0.1);
}

.bd__title {
  font-size: var(--font-h1);
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  word-break: break-all;
}

.bd__author {
  font-size: var(--font-body);
  color: var(--color-text-tertiary);
}

.bd__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  justify-content: center;
}

.bd__tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  font-size: var(--font-tiny);
  background-color: var(--color-border-light);
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
}

.bd__tag--primary {
  background-color: var(--color-primary-bg);
  color: var(--color-primary);
}

.bd__fav {
  margin-top: var(--space-sm);
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--color-border);
  background-color: var(--color-bg-card);
  color: var(--color-text-secondary);
  transition: all var(--ease-quick);
}
.bd__fav--hover {
  transform: scale(0.97);
}
.bd__fav--active {
  background-color: var(--color-warning-bg);
  border-color: rgba(245, 166, 35, 0.4);
  color: var(--color-warning);
}

.bd__fav-ico {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bd__fav-star {
  width: 24rpx;
  height: 24rpx;
  background-color: currentColor;
  clip-path: polygon(
    50% 0%,
    61% 35%,
    98% 35%,
    68% 57%,
    79% 91%,
    50% 70%,
    21% 91%,
    32% 57%,
    2% 35%,
    39% 35%
  );
}

.bd__fav-label {
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.bd__section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.bd__section-title {
  font-size: var(--font-h3);
  font-weight: 500;
  color: var(--color-text-primary);
}

.bd__section-hint {
  font-size: var(--font-tiny);
  color: var(--color-text-tertiary);
}

/* M8 PR2.6: 拍照集快捷入口卡片 */
.bd__photo-set-card {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-lg);
  transition: transform var(--ease-quick), background-color var(--ease-quick);
}
.bd__photo-set-card--hover {
  transform: scale(0.99);
  background-color: var(--color-primary-bg-soft);
}
.bd__photo-set-ico {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background-color: var(--color-primary-bg-soft);
  flex-shrink: 0;
}
.bd__photo-set-cam {
  position: absolute;
  top: 22rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 18rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: 8rpx;
  background-color: #fff;
}
.bd__photo-set-cam::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 14rpx;
  width: 18rpx;
  height: 8rpx;
  background-color: var(--color-primary);
  border-radius: 4rpx 4rpx 0 0;
}
.bd__photo-set-cam-lens {
  position: absolute;
  top: 36rpx;
  left: 26rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-primary);
  background-color: var(--color-primary-bg-soft);
}
.bd__photo-set-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.bd__photo-set-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}
.bd__photo-set-sub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.4;
}
.bd__photo-set-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid var(--color-text-tertiary);
  border-right: 3rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
  flex-shrink: 0;
  margin-right: 8rpx;
}

.bd__desc {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
  line-height: 1.7;
  white-space: pre-line;
}

.bd__expand {
  margin-top: var(--space-xs);
  color: var(--color-primary);
  font-size: var(--font-caption);
}

.bd__chapters {
  display: flex;
  flex-direction: column;
}

.bd__chapter {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--color-border-light);
  transition: background-color var(--ease-quick);
}

.bd__chapter:last-child {
  border-bottom: none;
}

.bd__chapter--active {
  background-color: var(--color-primary-bg);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  border-bottom: none;
}

.bd__chapter-tick {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 2rpx solid var(--color-border);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.bd__chapter--active .bd__chapter-tick {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: var(--color-text-inverse);
}

.bd__chapter-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bd__chapter-title {
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

.bd__chapter-meta {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-top: 4rpx;
}

.bd__chapter-page {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
}

.bd__chapter-flag {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  font-size: var(--font-tiny);
  border-radius: var(--radius-sm);
  background-color: var(--color-border-light);
  color: var(--color-text-tertiary);
}

.bd__chapter-flag--ready {
  background-color: var(--color-success-bg, rgba(36, 173, 113, 0.12));
  color: var(--color-success, #1f9b66);
}

.bd__action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--space-sm) var(--space-lg) var(--space-md);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background-color: rgba(250, 250, 247, 0.95);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid var(--color-border-light);
}

.bd__status-tip {
  font-size: var(--font-tiny);
  color: var(--color-text-tertiary);
  text-align: center;
  margin-bottom: var(--space-xs);
}

.bd__action-row {
  display: flex;
  gap: var(--space-sm);
}

.bd__action-btn {
  margin: 0;
}

.bd__action-btn--read {
  flex: 0 0 38%;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background-color: var(--color-bg-card);
}

.bd__action-btn--read[disabled] {
  border-color: var(--color-border-light);
  color: var(--color-text-disabled);
  background-color: var(--color-bg-card);
}

.bd__action-btn--paper {
  flex: 1 1 auto;
}
