.login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 96rpx var(--space-xl) var(--space-xl);
  background-color: var(--color-bg-page);
  box-sizing: border-box;
}

.login__hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
  padding-bottom: var(--space-xl);
}

.login__logo {
  font-size: 160rpx;
  line-height: 1;
  margin-bottom: var(--space-md);
}

.login__title {
  font-size: var(--font-display);
  font-weight: 700;
  color: var(--color-text-primary);
}

.login__subtitle {
  font-size: var(--font-body);
  color: var(--color-text-tertiary);
}

.login__actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}

.login__btn-primary {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
}

.login__btn-ghost {
  width: 100%;
  background-color: transparent;
  color: var(--color-primary);
  font-size: var(--font-body);
  border: none;
}

.login__btn-ghost::after {
  border: none;
}

.login__privacy {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-md);
}

.login__check {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-inverse);
  font-size: 24rpx;
  flex-shrink: 0;
  transition: all var(--ease-quick);
}

.login__check--on {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.login__privacy-text {
  flex: 1;
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.login__privacy-link {
  color: var(--color-primary);
  font-size: var(--font-caption);
}

.login__footer {
  text-align: center;
  margin-top: var(--space-xl);
}
