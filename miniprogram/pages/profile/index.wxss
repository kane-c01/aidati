.pf {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: 200rpx;
}

.pf__head {
  display: flex;
  justify-content: flex-end;
  padding: var(--space-md) var(--space-lg) 0;
}

.pf__settings {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

.pf__main {
  padding: var(--space-md) var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.pf__user {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md) 0;
}

.pf__avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: var(--color-border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.pf__avatar-img {
  width: 100%;
  height: 100%;
}

.pf__avatar-fallback {
  font-size: 64rpx;
  color: var(--color-text-tertiary);
}

.pf__user-meta {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.pf__nickname {
  font-size: var(--font-h2);
  font-weight: 500;
  color: var(--color-text-primary);
}

.pf__role {
  font-size: var(--font-tiny);
  color: var(--color-text-secondary);
  background-color: var(--color-primary-bg);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
  align-self: flex-start;
}

.pf__stats {
  display: flex;
  justify-content: space-around;
}

.pf__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
}

.pf__stat-num {
  font-size: var(--font-h1);
  font-weight: 700;
  color: var(--color-text-primary);
}

.pf__stat-label {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
}

.pf__section {
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.pf__row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md);
  border-bottom: 1rpx solid var(--color-border-light);
}

.pf__row:last-child {
  border-bottom: none;
}

.pf__row-icon {
  width: 48rpx;
  font-size: 32rpx;
  text-align: center;
}

.pf__row-title {
  flex: 1;
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

.pf__row-extra {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
  margin-right: var(--space-xs);
}

.pf__row-arrow {
  font-size: var(--font-h2);
  color: var(--color-text-tertiary);
}

.pf__row--disabled {
  color: var(--color-text-disabled);
}

.pf__row--disabled .pf__row-title {
  color: var(--color-text-disabled);
}
