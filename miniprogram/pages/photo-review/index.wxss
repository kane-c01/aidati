.pr {
  padding: var(--space-lg) var(--space-lg) 200rpx;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.pr__loading {
  padding: 96rpx 0;
}

.pr__head {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--color-border-light);
}

.pr__head-actions {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.pr__head-meta {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  margin-right: auto;
}

.pr__head-link {
  font-size: var(--font-caption);
  color: var(--color-primary);
  padding: 2rpx 12rpx;
}

.pr__head-title {
  font-size: var(--font-h2);
  font-weight: 500;
  color: var(--color-text-primary);
}

.pr__head-hint {
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
}

.pr__item {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  transition: opacity 0.2s ease;
}

.pr__item--unselected {
  opacity: 0.55;
}

.pr__check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  background-color: var(--color-bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pr__check--on {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.pr__check-tick {
  width: 12rpx;
  height: 6rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg) translateY(-2rpx);
}

.pr__item-no {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-size: var(--font-caption);
  color: var(--color-text-tertiary);
  flex-wrap: wrap;
}

.pr__item-region-tag {
  font-size: var(--font-tiny);
  color: var(--color-primary);
  background-color: rgba(91, 91, 214, 0.1);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-pill);
}

.pr__item-region-btn {
  margin-left: auto;
  font-size: var(--font-tiny);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
}

/* 同行有「重裁」+「框选区域」两个按钮时, 第二个不再 push-right, 紧贴第一个右侧 */
.pr__item-region-btn + .pr__item-region-btn {
  margin-left: 0;
}

/* ghost 变体: 次要操作 */
.pr__item-region-btn--ghost {
  color: var(--color-text-secondary);
  border-color: var(--color-border);
}

.pr__item-img {
  width: 100%;
  max-height: 480rpx;
  border-radius: var(--radius-sm);
  background-color: var(--color-border-light);
  margin-bottom: var(--space-sm);
}

.pr__item-label {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.pr__item-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: var(--space-sm);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-body);
  color: var(--color-text-primary);
  line-height: 1.6;
  background-color: var(--color-bg-page);
  box-sizing: border-box;
}

.pr__item-warn {
  font-size: var(--font-caption);
  color: var(--color-warning);
  background-color: var(--color-warning-bg);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
}

.pr__action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background-color: rgba(250, 250, 247, 0.95);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid var(--color-border-light);
  display: flex;
  gap: var(--space-sm);
}

.pr__action button {
  flex: 1;
}

.pr__action .pr__action-side {
  flex: 0 0 240rpx;
}
