.cap {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 0 32rpx 200rpx;
}

/* ======================================================================
 * 顶栏
 * ====================================================================== */

.cap__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 110rpx 0 20rpx;
  gap: 16rpx;
}

.cap__top-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.cap__top-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.cap__top-sub {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.4rpx;
}

.cap__counter {
  display: inline-flex;
  align-items: baseline;
  gap: 2rpx;
  padding: 10rpx 20rpx;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: 999rpx;
  flex-shrink: 0;
}
.cap__counter-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: -0.5rpx;
  line-height: 1;
  font-feature-settings: 'tnum' 1;
}
.cap__counter-divider {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin: 0 4rpx;
}
.cap__counter-max {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* ======================================================================
 * 文件导入卡片(M8 PR2.6)
 * ====================================================================== */

.cap__import {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: 24rpx;
  transition: transform var(--ease-quick), background-color var(--ease-quick);
}
.cap__import--hover {
  transform: scale(0.98);
  background-color: var(--color-primary-bg-soft);
}

.cap__import-ico {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background-color: var(--color-primary-bg-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cap__import-doc {
  position: relative;
  width: 36rpx;
  height: 44rpx;
  background-color: #fff;
  border: 2rpx solid var(--color-primary);
  border-radius: 4rpx;
  box-sizing: border-box;
  padding: 14rpx 6rpx 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.cap__import-doc-fold {
  position: absolute;
  top: -1rpx;
  right: -1rpx;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 0 12rpx 12rpx 0;
  border-color: transparent var(--color-primary-bg) transparent transparent;
}
.cap__import-doc-line {
  height: 3rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
}
.cap__import-doc-line--short {
  width: 60%;
}

.cap__import-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.cap__import-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}
.cap__import-sub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.4;
}

.cap__import-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid var(--color-text-tertiary);
  border-right: 3rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
  flex-shrink: 0;
  margin-right: 8rpx;
}

/* ======================================================================
 * 取景区
 * ====================================================================== */

.cap__view {
  position: relative;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: 24rpx;
  aspect-ratio: 4 / 3;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 4 角 bracket */
.cap__bracket {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
}
.cap__bracket--tl {
  top: 24rpx;
  left: 24rpx;
  border-top: 4rpx solid var(--color-primary);
  border-left: 4rpx solid var(--color-primary);
  border-top-left-radius: 8rpx;
}
.cap__bracket--tr {
  top: 24rpx;
  right: 24rpx;
  border-top: 4rpx solid var(--color-primary);
  border-right: 4rpx solid var(--color-primary);
  border-top-right-radius: 8rpx;
}
.cap__bracket--bl {
  bottom: 24rpx;
  left: 24rpx;
  border-bottom: 4rpx solid var(--color-primary);
  border-left: 4rpx solid var(--color-primary);
  border-bottom-left-radius: 8rpx;
}
.cap__bracket--br {
  bottom: 24rpx;
  right: 24rpx;
  border-bottom: 4rpx solid var(--color-primary);
  border-right: 4rpx solid var(--color-primary);
  border-bottom-right-radius: 8rpx;
}

.cap__view-empty {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  text-align: center;
}

.cap__book {
  position: relative;
  width: 220rpx;
  height: 160rpx;
  display: flex;
  background-color: #fff;
  border-radius: 8rpx;
  border: 1rpx solid var(--color-border-light);
  margin-bottom: 8rpx;
}
.cap__book-spine {
  position: absolute;
  left: 50%;
  top: 12rpx;
  bottom: 12rpx;
  width: 2rpx;
  background-color: var(--color-border);
  transform: translateX(-50%);
}
.cap__book-page {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 18rpx;
}
.cap__book-line {
  height: 4rpx;
  background-color: var(--color-border);
  border-radius: 2rpx;
}
.cap__book-line--short {
  width: 60%;
}

.cap__view-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.cap__view-desc {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

/* 已有照片:展示最新 */
.cap__view-thumb {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: stretch;
  padding: 0;
  margin: -40rpx;
}

.cap__view-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}

.cap__view-thumb-meta {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-image: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.55) 100%);
}

.cap__view-thumb-page {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.5rpx;
}

.cap__view-thumb-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ======================================================================
 * 进度条
 * ====================================================================== */

.cap__progress {
  margin-top: 20rpx;
  height: 6rpx;
  background-color: var(--color-border-light);
  border-radius: 999rpx;
  overflow: hidden;
}
.cap__progress-bar {
  height: 100%;
  background-color: var(--color-primary);
  border-radius: 999rpx;
  transition: width var(--ease-base);
  min-width: 0;
}

/* ======================================================================
 * 三按钮
 * ====================================================================== */

.cap__actions {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding: 32rpx 0 16rpx;
}

.cap__act {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: transform var(--ease-quick);
}
.cap__act--hover {
  transform: scale(0.94);
}
.cap__act--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.cap__act-ico {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cap__act-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.5rpx;
}

/* album icon */
.cap__ico-album {
  position: relative;
  width: 36rpx;
  height: 32rpx;
}
.cap__ico-album-frame {
  position: absolute;
  inset: 0;
  border: 3rpx solid var(--color-text-secondary);
  border-radius: 6rpx;
  box-sizing: border-box;
}
.cap__ico-album-mt {
  position: absolute;
  bottom: 4rpx;
  left: 4rpx;
  width: 14rpx;
  height: 12rpx;
  background-color: var(--color-text-secondary);
  clip-path: polygon(0% 100%, 50% 30%, 100% 100%);
}
.cap__ico-album::after {
  content: '';
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background-color: var(--color-text-secondary);
}

/* eye icon */
.cap__ico-eye {
  position: relative;
  width: 38rpx;
  height: 26rpx;
  border: 3rpx solid var(--color-text-secondary);
  border-radius: 19rpx 19rpx 19rpx 19rpx / 22rpx 22rpx 22rpx 22rpx;
  box-sizing: border-box;
}
.cap__ico-eye-iris {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: var(--color-text-secondary);
  transform: translate(-50%, -50%);
}

/* main button (大圆) */
.cap__act--main {
  position: relative;
  width: 156rpx;
  height: 156rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 8rpx;
  flex-direction: column;
}
.cap__act--main-hover {
  transform: scale(0.96);
}

.cap__act-main-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid var(--color-primary-bg);
}

.cap__act-main-circle {
  position: relative;
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(91, 91, 214, 0.28);
}

.cap__ico-shutter {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #fff;
  border: 4rpx solid var(--color-primary);
  box-sizing: border-box;
}

.cap__act-main-label {
  position: absolute;
  bottom: -8rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
  background-color: #fff;
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--color-primary-bg);
  letter-spacing: 1rpx;
}

.cap__act--main.cap__act--disabled .cap__act-main-circle {
  background-color: var(--color-primary-disabled);
  box-shadow: none;
}
.cap__act--main.cap__act--disabled .cap__act-main-label {
  color: var(--color-text-tertiary);
  border-color: var(--color-border-light);
}

/* ======================================================================
 * 已拍画廊
 * ====================================================================== */

.cap__gallery {
  margin-top: 32rpx;
  padding: 24rpx;
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: 24rpx;
}

.cap__gallery-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.cap__gallery-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.cap__gallery-hint {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.cap__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.cap__cell {
  position: relative;
  aspect-ratio: 3 / 4;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: var(--color-border-light);
  transition: transform var(--ease-quick);
}
.cap__cell--hover {
  transform: scale(0.96);
}

.cap__cell-img {
  width: 100%;
  height: 100%;
  display: block;
}

.cap__cell-page {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 6rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0.5rpx;
}

.cap__cell-x {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cap__cell-x-line {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 2rpx;
  background-color: #fff;
  border-radius: 1rpx;
  transform: translate(-50%, -50%) rotate(45deg);
}
.cap__cell-x-line--2 {
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* 左下角「✂」裁剪入口, 显式按钮, 不依赖长按 */
.cap__cell-crop {
  position: absolute;
  bottom: 6rpx;
  left: 6rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background-color: rgba(91, 91, 214, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
}
.cap__cell-crop-text {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}

.cap__cell--add {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary-bg-soft);
  border: 2rpx dashed rgba(91, 91, 214, 0.4);
}
.cap__cell--add-hover {
  background-color: var(--color-primary-bg);
  transform: scale(0.96);
}

.cap__cell-plus {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}
.cap__cell-plus-h,
.cap__cell-plus-v {
  position: absolute;
  background-color: var(--color-primary);
  border-radius: 2rpx;
}
.cap__cell-plus-h {
  top: 50%;
  left: 0;
  right: 0;
  height: 4rpx;
  transform: translateY(-50%);
}
.cap__cell-plus-v {
  left: 50%;
  top: 0;
  bottom: 0;
  width: 4rpx;
  transform: translateX(-50%);
}

/* ======================================================================
 * 提示
 * ====================================================================== */

.cap__hint {
  margin-top: 24rpx;
  padding: 0 4rpx;
}

.cap__hint-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.6;
  letter-spacing: 0.4rpx;
}

/* ======================================================================
 * 完成 CTA
 * ====================================================================== */

.cap__finish {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.cap__finish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  width: 100%;
  height: 100rpx;
  border-radius: 18rpx;
  background-color: var(--color-primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1.5rpx;
  transition: transform var(--ease-quick), opacity var(--ease-quick);
}
.cap__finish-btn--hover {
  transform: scale(0.98);
  opacity: 0.92;
}
.cap__finish-btn--disabled {
  background-color: var(--color-primary-disabled);
  pointer-events: none;
}

.cap__finish-btn-ico {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cap__ico-check {
  position: relative;
  width: 18rpx;
  height: 12rpx;
}
.cap__ico-check::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 8rpx;
  border-bottom: 3rpx solid #fff;
  border-left: 3rpx solid #fff;
  transform: translate(-50%, -65%) rotate(-45deg);
}

.cap__finish-btn-spin {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.32);
  border-top-color: #fff;
  animation: cap-spin 0.8s linear infinite;
}

@keyframes cap-spin {
  to {
    transform: rotate(360deg);
  }
}

.cap__finish-meta {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 0.4rpx;
}

/* AI disclaimer 居中 */
.cap > ai-disclaimer {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.cap__spacer {
  height: 140rpx;
}
