{
  "name": "ai-quiz-admin-web",
  "version": "0.1.0",
  "private": true,
  "description": "AI 智能出题学习小程序 - 管理后台 Web 端 (Vue 3 + Vite + Element Plus)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint \"src/**/*.{vue,ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,scss}\"",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "element-plus": "^2.9.1",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
